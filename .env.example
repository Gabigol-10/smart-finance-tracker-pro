# Smart Finance Tracker Pro - Environment Variables

# App Configuration
VITE_APP_TITLE="Smart Finance Tracker Pro"
VITE_APP_VERSION="2.0.0"

# API Configuration (if using backend)
VITE_API_URL="http://localhost:3000/api"
VITE_API_TIMEOUT=10000

# Authentication (if implementing)
VITE_AUTH_ENABLED=false
VITE_JWT_SECRET="your-secret-key-here"

# Features Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_EXPORT=true
VITE_ENABLE_NOTIFICATIONS=true

# Third Party Services (optional)
VITE_GOOGLE_ANALYTICS_ID=""
VITE_SENTRY_DSN=""

# Development
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL="info"

# Theme
VITE_DEFAULT_THEME="dark"

# Currency & Locale
VITE_DEFAULT_CURRENCY="USD"
VITE_DEFAULT_LOCALE="es-MX"
